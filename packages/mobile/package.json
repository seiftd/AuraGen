{
  "name": "@auragen/mobile",
  "version": "1.0.0",
  "description": "AuraGen AI Mobile App - React Native",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@auragen/shared": "1.0.0",
    "expo": "^50.0.0",
    "expo-av": "~14.0.0",
    "expo-camera": "~14.0.0",
    "expo-constants": "~15.4.0",
    "expo-dev-client": "~3.3.0",
    "expo-file-system": "~16.0.0",
    "expo-font": "~11.10.0",
    "expo-image": "~1.10.0",
    "expo-image-picker": "~14.7.0",
    "expo-localization": "~14.8.0",
    "expo-media-library": "~15.9.0",
    "expo-notifications": "~0.27.0",
    "expo-router": "~3.4.0",
    "expo-sharing": "~11.10.0",
    "expo-splash-screen": "~0.26.0",
    "expo-status-bar": "~1.11.0",
    "expo-video": "~1.0.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-reanimated": "~3.6.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "native-base": "^3.4.28",
    "react-native-vector-icons": "^10.0.3",
    "react-hook-form": "^7.48.2",
    "react-query": "^3.39.3",
    "axios": "^1.6.2",
    "react-i18next": "^13.5.0",
    "i18next": "^23.7.16",
    "react-native-localize": "^3.0.6",
    "react-native-mmkv": "^2.11.0",
    "react-native-keychain": "^8.2.0",
    "react-native-device-info": "^10.12.0",
    "react-native-orientation-locker": "^1.7.0",
    "react-native-share": "^10.0.2",
    "react-native-sound": "^0.11.2",
    "react-native-video": "^5.2.1",
    "lottie-react-native": "^6.4.1",
    "react-native-super-grid": "^4.9.7",
    "react-native-modal": "^13.0.1",
    "react-native-progress": "^5.0.1",
    "react-native-slider": "^2.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/runtime": "^7.23.6",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "eslint": "^8.56.0",
    "eslint-config-expo": "^7.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^50.0.0",
    "metro": "^0.80.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": ["react-native-safe-area-context"]
    }
  }
}